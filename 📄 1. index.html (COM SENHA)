<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Sistema</title>

<style>
body { background:#0f0f0f; color:#fff; font-family:Arial; text-align:center; padding:40px;}
input { padding:10px; border-radius:8px; border:none;}
button { padding:10px; border:none; border-radius:8px;}
</style>

</head>

<body>

<div id="login">
  <h2>Acesso restrito</h2>
  <input type="password" id="senha" placeholder="Senha">
  <button onclick="entrar()">Entrar</button>
</div>

<div id="app" style="display:none;">
  <h2>Consulta</h2>

  <input id="busca" placeholder="familia 126 fabrica 2 bolsa">
  <button onclick="buscar()">Buscar</button>

  <pre id="resultado"></pre>
</div>

<script>
const SENHA = "123456"; // TROCA ISSO

function entrar() {
  if (document.getElementById("senha").value === SENHA) {
    document.getElementById("login").style.display = "none";
    document.getElementById("app").style.display = "block";
  } else {
    alert("Senha incorreta");
  }
}
</script>

<script src="script.js"></script>

</body>
</html>
